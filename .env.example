# ── Base de datos ──────────────────────────────────────────────────────────────
# Desarrollo: SQLite local (por defecto, no hace falta configurar nada)
# DATABASE_URL=sqlite:///./turnos_pablo.db

# Producción: Railway agrega esto automáticamente al conectar el plugin PostgreSQL
# DATABASE_URL=postgresql://user:password@host:5432/railway

# ── CORS ───────────────────────────────────────────────────────────────────────
# Desarrollo: dejar en * para permitir todo
ALLOWED_ORIGINS=*

# Producción: poner la URL del dashboard de Pablo (separadas por coma si hay varias)
# ALLOWED_ORIGINS=https://mi-dashboard.netlify.app,https://pablo.gestion-ai.com
